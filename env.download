.page { min-height: 100vh; background: var(--cream); }

.topBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 32px;
  background: var(--white);
  border-bottom: 1px solid var(--border);
}
.logo { font-size: 1.2rem; font-weight: 800; text-decoration: none; letter-spacing: -0.3px; }
.green { color: var(--green); }
.gold { color: var(--gold); }
.loginLink { font-size: 0.875rem; color: var(--grey); text-decoration: none; }
.loginLink:hover { color: var(--green); }

.container { max-width: 960px; margin: 0 auto; padding: 48px 24px; }

.stepHeader { text-align: center; margin-bottom: 40px; }
.stepBadge {
  display: inline-block;
  background: var(--green-light);
  color: var(--green);
  font-size: 0.75rem;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 50px;
  margin-bottom: 16px;
  letter-spacing: 0.5px;
}
.stepHeader h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; color: var(--dark); margin-bottom: 8px; letter-spacing: -0.5px; }
.stepHeader p { font-size: 1rem; color: var(--grey); }

/* Plan grid */
.plansGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 32px;
}
.planCard {
  background: var(--white);
  border: 2px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
}
.planCard:hover { border-color: var(--green); box-shadow: var(--shadow); }
.selected { border-color: var(--green) !important; box-shadow: 0 0 0 1px var(--green), var(--shadow); }
.featured { border-color: #c8e6d4; }

.planBadge {
  position: absolute;
  top: -10px; left: 50%; transform: translateX(-50%);
  background: var(--gold);
  color: var(--white);
  font-size: 0.65rem;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 50px;
  white-space: nowrap;
}
.planRadio { margin-bottom: 12px; }
.radio {
  width: 18px; height: 18px;
  border: 2px solid var(--border);
  border-radius: 50%;
  transition: all 0.2s;
}
.radioSelected { border-color: var(--green); background: var(--green); box-shadow: inset 0 0 0 3px var(--white); }

.planName { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--grey); margin-bottom: 4px; }
.planPrice { font-size: 1.6rem; font-weight: 800; color: var(--dark); line-height: 1; margin-bottom: 2px; }
.planPrice span { font-size: 0.8rem; font-weight: 500; color: var(--grey); }
.planTagline { font-size: 0.78rem; color: var(--grey); margin-bottom: 14px; padding-bottom: 14px; border-bottom: 1px solid var(--border); line-height: 1.4; }
.planFeatures { list-style: none; }
.planFeatures li { display: flex; align-items: flex-start; gap: 6px; font-size: 0.78rem; color: var(--dark); margin-bottom: 7px; line-height: 1.4; }
.planFeatures li span { color: var(--green); font-weight: 700; flex-shrink: 0; font-size: 0.8rem; }

.planCta { text-align: center; }
.planCtaNote { font-size: 0.82rem; color: var(--grey); margin-top: 12px; }

/* Form */
.formCard {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 40px;
  max-width: 480px;
  margin: 0 auto;
  box-shadow: var(--shadow);
}
.form { display: flex; flex-direction: column; gap: 20px; }
.field { display: flex; flex-direction: column; gap: 6px; }
.field label { font-size: 0.875rem; font-weight: 600; color: var(--dark); }
.field input {
  padding: 12px 16px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 0.95rem;
  font-family: inherit;
  color: var(--dark);
  background: var(--white);
  transition: border-color 0.2s;
  outline: none;
}
.field input:focus { border-color: var(--green); }
.fieldHint { font-size: 0.75rem; color: var(--grey); }
.error {
  background: #FEF2F2;
  border: 1px solid #FECACA;
  color: #DC2626;
  padding: 10px 14px;
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
}
.backBtn {
  display: block;
  width: 100%;
  text-align: center;
  margin-top: 16px;
  background: none;
  border: none;
  color: var(--grey);
  font-size: 0.875rem;
  cursor: pointer;
  font-family: inherit;
  padding: 8px;
}
.backBtn:hover { color: var(--dark); }

/* Payment */
.paymentSummary {
  background: var(--grey-light);
  border-radius: var(--radius-sm);
  padding: 20px;
  margin-bottom: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.paymentRow { display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; }
.paymentRow span { color: var(--grey); }

.paymentDummy { text-align: center; padding: 16px 0; }
.paymentDummyIcon { font-size: 2.5rem; margin-bottom: 12px; }
.paymentDummy h3 { font-size: 1.1rem; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
.paymentDummy p { font-size: 0.875rem; color: var(--grey); line-height: 1.6; margin-bottom: 20px; }

.btnWhatsapp {
  display: block;
  background: #25D366;
  color: var(--white);
  padding: 13px 24px;
  border-radius: 50px;
  font-weight: 700;
  font-size: 0.95rem;
  text-decoration: none;
  margin-bottom: 12px;
  transition: opacity 0.2s;
}
.btnWhatsapp:hover { opacity: 0.9; }
.skipBtn {
  background: none;
  border: none;
  color: var(--grey);
  font-size: 0.82rem;
  cursor: pointer;
  font-family: inherit;
  text-decoration: underline;
  padding: 8px;
}

/* Shared button */
.btnPrimary {
  background: var(--green);
  color: var(--white);
  padding: 14px 28px;
  border-radius: 50px;
  font-weight: 700;
  font-size: 1rem;
  border: none;
  cursor: pointer;
  font-family: inherit;
  transition: background 0.2s;
  width: 100%;
}
.btnPrimary:hover:not(:disabled) { background: var(--green-dark); }
.btnPrimary:disabled { opacity: 0.6; cursor: not-allowed; }

@media (max-width: 800px) {
  .plansGrid { grid-template-columns: 1fr 1fr; }
  .formCard { padding: 28px 20px; }
}
@media (max-width: 480px) {
  .plansGrid { grid-template-columns: 1fr; }
  .topBar { padding: 16px 20px; }
}
